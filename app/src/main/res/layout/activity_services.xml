<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ServicesActivity">

    <!-- App Bar com barra de pesquisa -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_color"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Serviços"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/btnPopulateData"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:gravity="center"
                android:text="Encontre o serviço certo e avance sem aperto na tela"
                android:textColor="@color/white_90"
                android:textSize="13sp" />

            <!-- Barra de pesquisa -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/gray_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Buscar serviços..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="16sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Conteúdo Principal -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/gray_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categorias"
                        android:textAllCaps="true"
                        android:textColor="@color/primary_color"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Escolha o tipo de serviço"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tudo foi alinhado para caber melhor em celulares menores."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Grid de nichos de serviços -->
            <GridLayout
                android:id="@+id/serviceGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="2dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true">

                <!-- Limpeza de estofados -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardLimpeza"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_cleaning"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Limpeza de estofados" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Encanador -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManutencao"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Encanador" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Elétrica -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEletrica"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_electrician"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Elétrica" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Instalação -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEncanamento"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_carpentry"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Instalação" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Caixa d'água -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardPintura"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Caixa d'água" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Desentupimento manual -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardJardinagem"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Desentupimento manual" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Desentupimento com maquinário (até 2m) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMudancas"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Desentupimento com maquinário até 2 m" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Caça-vazamentos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTecnologia"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Caça-vazamentos" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Faxina -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardFaxina"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_cleaning"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Faxina" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Ar condicionado -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardArCondicionado"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_services"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Ar condicionado" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Eletrodomésticos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardEletrodomesticos"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_it"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Eletrodomésticos" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Chaveiro residencial -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardChaveiroResidencial"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_services"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chaveiro residencial" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Serviços automotivos -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardServicosAutomotivos"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_services"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Serviços automotivos" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Montagem de móveis -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMontagemMoveis"
                    style="@style/ServiceCategoryCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:minHeight="152dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_carpentry"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            style="@style/ServiceCategoryLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Montagem de móveis" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Estado Vazio -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_services"
                    android:background="@drawable/circle_background_primary"
                    android:padding="24dp"
                    app:tint="@color/white"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhum serviço encontrado"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tente ajustar sua busca ou explore as categorias disponíveis"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Estado de Carregamento -->
            <LinearLayout
                android:id="@+id/loadingState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary_color"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carregando serviços..."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
